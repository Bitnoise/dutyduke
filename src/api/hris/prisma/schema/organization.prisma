model Organization {
  id        String   @id @default(cuid())
  name      String
  taxId     String?  @unique
  foundedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  companies              Company[]
  organizationAddress    OrganizationAddress?
  organizationAgreements OrganizationAgreements?
}

model OrganizationAddress {
  id             String       @id @default(cuid())
  address1       String /// @encrypted
  address2       String? /// @encrypted
  postalCode     String /// @encrypted
  city           String /// @encrypted
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model OrganizationAgreements {
  id                            String       @id @default(cuid())
  ip                            String       @default("") /// @encrypted
  termsAndServicesAgreement     Boolean
  representativePersonAgreement Boolean
  electronicAgreement           Boolean
  organizationId                String       @unique
  organization                  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt                     DateTime     @default(now())
}
