{
  "name": "dutyduke",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint && npx tsc --pretty",
    "fix": "next lint --fix",
    "prepare": "npx lefthook install",
    "prisma:remove:generated": "rm -rf .prisma-generated/*-client",
    "prisma:generate": "yarn prisma:remove:generated && prisma generate --schema src/api/hris/prisma/schema",
    "prisma:migrate": "prisma migrate dev --schema src/api/hris/prisma/schema",
    "prisma:migrate:deploy": "prisma migrate deploy --schema src/api/hris/prisma/schema",
    "prisma:reset": "prisma migrate reset --schema src/api/hris/prisma/schema",
    "prisma:studio": "prisma studio --schema src/api/hris/prisma/schema",
    "prisma:seed": "tsx src/api/hris/prisma/seed.ts",
    "create:owner": "tsx src/api/hris/scripts/create-owner.ts",
    "promote:owner": "tsx src/api/hris/scripts/create-owner.ts promote",
    "change:password": "tsx src/api/hris/scripts/create-owner.ts change-password",
    "organization:create": "tsx src/api/hris/scripts/create-organization.ts",
    "fixtures:load": "tsx src/api/hris/scripts/load-fixtures.ts",
    "fixtures:clean": "tsx src/api/hris/scripts/load-fixtures.ts --clean",
    "nuke": "rm -rf .next node_modules && yarn cache clean --force && yarn install --check-files"
  },
  "prisma": {
    "schema": "src/api/hris/prisma/schema"
  },
  "dependencies": {
    "@bitnoi.se/react-scheduler": "^0.3.1",
    "@paralleldrive/cuid2": "^2.2.2",
    "@prisma/client": "^5.18.0",
    "@types/qrcode": "^1.5.5",
    "@types/ua-parser-js": "^0.7.39",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.13",
    "handlebars": "^4.7.8",
    "ical-generator": "^8.1.1",
    "jotai": "^2.10.0",
    "jsonwebtoken": "^9.0.2",
    "jszip": "^3.10.1",
    "jwt-decode": "^4.0.0",
    "lodash.debounce": "^4.0.8",
    "next": "15",
    "next-intl": "^3.17.6",
    "nodemailer": "^6.9.15",
    "normalize-diacritics": "^5.0.0",
    "pino": "^9.7.0",
    "pino-pretty": "^13.0.0",
    "prisma-field-encryption": "^1.5.2",
    "qrcode": "^1.5.4",
    "react": "^18",
    "react-aria-components": "^1.3.1",
    "react-dom": "^18",
    "react-tooltip": "^5.28.1",
    "react-weekview": "^0.0.15",
    "tailwind-merge": "^2.5.2",
    "tsx": "^4.19.0",
    "ua-parser-js": "^1.0.39",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.6",
    "@types/lodash.debounce": "^4.0.9",
    "@types/node": "^20",
    "@types/nodemailer": "^6.4.15",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.1",
    "@typescript-eslint/parser": "^8.0.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8",
    "eslint-config-next": "15",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-tailwindcss": "^3.17.4",
    "lefthook": "^1.7.12",
    "postcss": "^8.4.41",
    "prettier": "^3.3.3",
    "prisma": "^5.18.0",
    "prisma-dbml-generator": "^0.12.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
